# Railway, PostgreSQL servisi eklendiğinde bu değişkeni otomatik sağlar.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# İlk yönetici hesabını bir kez oluşturmak için kullanılır; Railway'e kalıcı
# olarak eklemek gerekmez. Parola veritabanında yalnızca hash olarak tutulur.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-with-a-strong-password

# Open Graph ve canonical URL için üretim alan adınız.
NEXT_PUBLIC_SITE_URL=https://example.com

# Localhost ziyaretleri de varsayılan olarak kaydedilir. Yerel geliştirme
# trafiğini tamamen hariç tutmak isterseniz false yapabilirsiniz.
ANALYTICS_TRACK_LOCAL=true

# Cerilas SMS API. Bu değerler yalnızca sunucuda kullanılmalıdır.
CERILAS_SMS_BASE_URL=https://sms-api.example.com
CERILAS_SMS_EMAIL=sms-user@example.com
CERILAS_SMS_PASSWORD=change-me

# cron-job.org günlük özet çağrısını doğrulamak için uzun ve rastgele bir değer.
CRON_SECRET=generate-a-long-random-secret
